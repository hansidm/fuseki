PREFIX :       <#>
PREFIX fuseki: <http://jena.apache.org/fuseki#>
PREFIX rdf:    <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs:   <http://www.w3.org/2000/01/rdf-schema#>
PREFIX tdb2:   <http://jena.apache.org/2016/tdb#>
PREFIX text:   <http://jena.apache.org/text#>

[] a fuseki:Server ;
   fuseki:services ( :service ) .

:service a fuseki:Service ;
    rdfs:label "Fuseki dataset with Lucene full-text search" ;
    fuseki:name "ds" ;
    fuseki:serviceQuery "query" , "sparql" ;
    fuseki:serviceUpdate "update" ;
    fuseki:serviceReadGraphStore "get" ;
    fuseki:serviceReadWriteGraphStore "data" ;
    fuseki:dataset :text_dataset .

:text_dataset a text:TextDataset ;
    text:dataset :dataset ;
    text:index :index .

:dataset a tdb2:DatasetTDB2 ;
    tdb2:location "/ds/tdb2" .

:index a text:TextIndexLucene ;
    text:directory <file:/ds/lucene> ;
    text:entityMap :entity_map ;
    text:storeValues true ;
    text:analyzer [ a text:StandardAnalyzer ] ;
    text:queryParser text:AnalyzingQueryParser .

:entity_map a text:EntityMap ;
    text:entityField "uri" ;
    text:defaultField "label" ;
    text:uidField "uid" ;
    text:langField "lang" ;
    text:graphField "graph" ;
    text:map (
        [ text:field "label" ; text:predicate rdfs:label ]
    ) .
